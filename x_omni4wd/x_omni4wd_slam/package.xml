<?xml version="1.0"?>
<package format="2">
  <name>x_omni4wd_slam</name>
  <version>0.1.0</version>
  <description>
    RF2O-based laser odometry for x_omni4wd robot.
    Estimation of 2D odometry based on planar laser scans using Range Flow-based approach.
    Useful for mobile robots with inaccurate base odometry.
    
    Based on: Planar Odometry from a Radial Laser Scanner. A Range Flow-based Approach. ICRA 2016
  </description>

  <maintainer email="anhquyentp34@gmail.com">quyenanh pt</maintainer>
  <license>GPL v3</license>

  <buildtool_depend>catkin</buildtool_depend>

  <build_depend>roscpp</build_depend>
  <build_depend>std_msgs</build_depend>
  <build_depend>sensor_msgs</build_depend>
  <build_depend>nav_msgs</build_depend>
  <build_depend>geometry_msgs</build_depend>
  <build_depend>tf</build_depend>
  <build_depend>tf2</build_depend>
  <build_depend>tf2_ros</build_depend>
  <build_depend>eigen</build_depend>
  <build_depend>cmake_modules</build_depend>

  <exec_depend>roscpp</exec_depend>
  <exec_depend>std_msgs</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>nav_msgs</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>tf</exec_depend>
  <exec_depend>tf2</exec_depend>
  <exec_depend>tf2_ros</exec_depend>

  <!-- Hector SLAM (stack trong costmapex_unified_ws/src/hector_slam-noetic-devel hoặc ros-noetic-hector-mapping) -->
  <exec_depend>hector_mapping</exec_depend>

  <export>
  </export>
</package>

