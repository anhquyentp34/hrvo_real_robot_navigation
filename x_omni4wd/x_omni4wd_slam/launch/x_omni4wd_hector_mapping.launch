<?xml version="1.0"?>
<!--
  Hector SLAM trên x_omni4wd: laptop + RPLIDAR gá trên robot.

  Luồng:
    - x_omni4wd_bringup: URDF + robot_state_publisher, RPLIDAR (/scan), RF2O (TF odom->base_footprint).
    - Hector cần TF odom->base khi pub_map_odom_transform:=true; RF2O đáp ứng điều đó.

  Chạy:
    source /opt/ros/noetic/setup.bash
    source ~/costmapex_unified_ws/devel/setup.bash
    roslaunch x_omni4wd_slam x_omni4wd_hector_mapping.launch

  Lưu map (terminal khác; tạo t21.pgm và t21.yaml):
    rosrun map_server map_saver -f /home/quyenanhpt/costmapex_unified_ws/src/x_omni4wd_navigation/maps/t21

  Ghi chú:
    - use_zed mặc định false để nhẹ khi chỉ mapping.
    - Cổ LiDAR: lidar_port (truyền vào bringup qua arg nếu cần — xem x_omni4wd_bringup.launch).
-->
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_footprint"/>
  <arg name="laser_frame" default="lidar_link"/>
  <arg name="lidar_port" default="/dev/robot_lidar"/>
  <arg name="lidar_baud" default="115200"/>
  <arg name="use_zed" default="false"/>
  <arg name="open_rviz" default="true"/>
  <arg name="rviz_config" default="$(find x_omni4wd_slam)/rviz/x_omni4wd_hector_mapping.rviz"/>

  <include file="$(find x_omni4wd_bringup)/launch/x_omni4wd_bringup.launch">
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="scan_topic" value="$(arg scan_topic)"/>
    <arg name="odom_frame" value="$(arg odom_frame)"/>
    <arg name="base_frame" value="$(arg base_frame)"/>
    <arg name="laser_frame" value="$(arg laser_frame)"/>
    <arg name="lidar_port" value="$(arg lidar_port)"/>
    <arg name="lidar_baud" value="$(arg lidar_baud)"/>
    <arg name="use_lidar" value="true"/>
    <arg name="use_zed" value="$(arg use_zed)"/>
    <arg name="open_rviz" value="false"/>
    <arg name="use_rqt_omni_robot_steering" value="false"/>
  </include>

  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <rosparam file="$(find x_omni4wd_slam)/config/hector_x_omni4wd.yaml" command="load"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>

  <node if="$(arg open_rviz)" pkg="rviz" type="rviz" name="rviz_hector_mapping"
        args="-d $(arg rviz_config)" output="screen" required="false"/>
</launch>
