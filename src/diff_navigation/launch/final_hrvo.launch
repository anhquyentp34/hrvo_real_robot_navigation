<?xml version="1.0"?>

<launch>
<master auto="start"/>
<param name="use_sim_time" value="true"/>

  <!-- Arguments -->
  <arg name="open_rviz" default="true"/>
  <arg name="move_forward_only" default="false"/>
  <arg name="map_file" default="$(find diff_slam)/maps/kb1_1.yaml"/> <!-- kb_1 minh_map-->
  <arg name="enable_pedsim" default="true"/>
  <arg name="pedsim_scene_file" default="$(find pedsim_simulator)/scenarios/social_contexts.xml"/>
  <arg name="pedsim_people_topic" default="/people"/>
  <arg name="gpu" default="true"/>
  <arg name="velodyne_cloud_in" default="/velodyne_points_gpu"/>

  <!-- Robot URDF (Velodyne VLP-16 thay Hokuyu trong diff_bot.urdf.xacro) -->
  <param name="robot_description" command="$(find xacro)/xacro $(find diff_description)/urdf/diff_bot.urdf.xacro gpu:=$(arg gpu)"/>

  <!-- AMCL + map + pointcloud → scan -->
  <include file="$(find diff_slam)/launch/localization_velodyne.launch">
    <arg name="velodyne_cloud_in" value="$(arg velodyne_cloud_in)"/>
  </include>
  
  <!-- Log position of robot to draw a trajectory -->
 <!-- <node name="model_state_logger" pkg="my_robot_logger" type="robot_state_logger.py" output="screen"/> -->

  <!-- Move_base -->
  <include file="$(find diff_navigation)/launch/move_base_hrvo.launch">
    <arg name="use_tracked_people" value="$(arg enable_pedsim)"/>
    <arg name="tracked_people_topic" value="$(arg pedsim_people_topic)"/>
    <arg name="use_gazebo_agents" value="true"/>
  </include>

  <!-- Pedsim 2D crowd simulator + adapter -> /people -->
  <group if="$(arg enable_pedsim)">
    <include file="$(find pedsim_simulator)/launch/simulator.launch">
      <arg name="scene_file" value="$(arg pedsim_scene_file)"/>
      <arg name="with_robot" value="false"/>
      <arg name="simulation_factor" value="1.0"/>
      <arg name="update_rate" value="25.0"/>
      <arg name="default_queue_size" value="10"/>
      <arg name="robot_mode" value="1"/>
      <arg name="enable_groups" value="true"/>
    </include>
    <include file="$(find pedsim_visualizer)/launch/visualizer.launch"/>
    <node name="hrvo_pedestrian_adapter_node"
          pkg="hrvo_local_planner"
          type="hrvo_pedestrian_adapter_node.py"
          output="screen">
      <param name="input_topic" value="/pedsim_simulator/simulated_agents"/>
      <param name="output_people_topic" value="$(arg pedsim_people_topic)"/>
      <param name="default_radius" value="0.35"/>
      <param name="log_every_n" value="20"/>
    </node>
  </group>
  
  <!-- Launch the simple path publisher for 4 doctors -->
  <node name="simple_path_publisher" pkg="gazebo_ros_actor_plugin" type="multi_actor_path_publisher.py" output="screen">
  </node> 
  <!-- Launch hien marker nguoi -->
  <node name="sfm_local_plan_republisher" pkg="diff_navigation" type="sfm_local_plan_republisher.py" output="screen">
  </node>
    <!-- costmap group_actor-human
  <node name="social_cue_sim_original" pkg="social_cue_sim" type="social_cue_sim_original.py" output="screen">
  </node>  -->
  
  <!-- Launch tracking actor (minh) 
  <node name="human_tracking" pkg="diff_navigation" type="human_tracking.py" output="screen"> 
  </node> -->
    <!-- Launch hien marker waypoint
  <node name="waypoint" pkg="diff_navigation" type="waypoint.py" output="screen">
  </node> -->
  
 <!--  **************** Visualisation ****************  -->
 <group if="$(arg open_rviz)"> 
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find diff_rviz)/rviz/final.rviz"/>
 </group>
 <!-- ✅ Relay scan -> scan_filtered để đảm bảo SFM nhận được  chạy teb thì tắt
  <node name="relay_scan_filtered" pkg="topic_tools" type="relay" args="/scan /scan_filtered" />-->
</launch>
