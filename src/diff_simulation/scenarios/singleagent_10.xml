  <agent x="6.5" y="4.5" n="2" dx="0.8" dy="0.8" type="2">
    <addwaypoint id="w_right_mid"/>
    <addwaypoint id="w_center"/>
    <addwaypoint id="w_left_top"/>
    <addwaypoint id="w_left_mid"/>
  </agent>

  <agent x="6.5" y="-4.5" n="2" dx="0.8" dy="0.8" type="3">
    <addwaypoint id="w_right_mid"/>
    <addwaypoint id="w_gap"/>
    <addwaypoint id="w_left_bot"/>
    <addwaypoint id="w_left_mid"/>
  </agent>

  <agent x="-0.5" y="0.0" n="2" dx="0.6" dy="0.6" type="0">
    <addwaypoint id="w_center"/>
    <addwaypoint id="w_right_mid"/>
    <addwaypoint id="w_left_mid"/>
