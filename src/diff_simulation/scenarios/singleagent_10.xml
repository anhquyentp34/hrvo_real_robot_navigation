  <waypoint id="w_gap" x="-1.0" y="-1.8" r="1.0"/>

  <!-- 10 pedestrians total -->
  <agent x="-7.5" y="4.5" n="2" dx="0.8" dy="0.8" type="0">
    <addwaypoint id="w_left_mid"/>
    <addwaypoint id="w_center"/>
    <addwaypoint id="w_right_top"/>
    <addwaypoint id="w_right_mid"/>
