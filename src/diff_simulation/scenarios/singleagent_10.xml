  <agent x="-7.5" y="-4.5" n="2" dx="0.8" dy="0.8" type="1">
    <addwaypoint id="w_left_mid"/>
    <addwaypoint id="w_gap"/>
    <addwaypoint id="w_right_bot"/>
    <addwaypoint id="w_right_mid"/>
