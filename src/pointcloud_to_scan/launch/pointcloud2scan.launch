<?xml version="1.0"?>

<launch>
  <!-- run pointcloud_to_laserscan node -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">

       <!-- <remap from="cloud_in" to="/velodyne_points_cpu"/> -->
          <remap from="cloud_in" to="/velodyne_points_gpu"/> 
	<!-- <remap from="cloud_in" to="/velodyne_points"/> -->
        <!--remap from="scan" to="/camera/scan"/-->

        <rosparam>
            #target_frame: upper_base_link 
            transform_tolerance: 0.01
            min_height: 0.0
            max_height: 1.0

            angle_min: -3.14 # -M_PI
            angle_max: 3.14 # M_PI
            angle_increment: 0.0087 # M_PI/360.0
            scan_time: 0.0 # 0.3333
            rate: 40.0
            range_min: 0.45
            range_max: 10.0
            concurrency_level: 0 # defaul: 1
            use_inf: true
        </rosparam>
    </node>
</launch>
