<?xml version="1.0"?>
<launch>
  <!--
    Complete Gazebo SLAM launch file for x_omni4wd robot.

    This launch file integrates:
    1. Gazebo simulation with robot and controllers
    2. RF2O Laser Odometry (odom -> base_footprint)
    3. Hector SLAM (map -> odom)
    4. RViz visualization

    TF Tree: map -> odom -> base_footprint -> base_link -> lidar_link

    Topics:
      - /scan: Laser scan data (from Gazebo)
      - /odom: Odometry from RF2O (nav_msgs/Odometry)
      - /map: Occupancy grid map from Hector (nav_msgs/OccupancyGrid)
      - /cmd_vel: Velocity commands (geometry_msgs/Twist)

    Usage:
      roslaunch x_omni4wd_gazebo gazebo_slam.launch
      roslaunch x_omni4wd_gazebo gazebo_slam.launch world:=empty world_file:=$(find x_omni4wd_gazebo)/worlds/empty.world
  -->

  <!-- Arguments -->
  <arg name="world" default="empty" />
  <arg name="world_file" default="$(find x_omni4wd_gazebo)/worlds/empty.world" />
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="x" default="0.0" />
  <arg name="y" default="0.0" />
  <arg name="z" default="0.1" />
  <arg name="urdf_file" default="$(find x_omni4wd_description)/urdf/x_omni4wd_description.urdf" />
  <arg name="use_rviz" default="true" />
  <arg name="use_rqt_robot_steering" default="true" />
  <arg name="scan_topic" default="/scan"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_footprint"/>
  <arg name="rviz_config" default="$(find x_omni4wd_gazebo)/rviz/slam.rviz"/>

  <!-- Include Gazebo simulation with robot and controllers -->
  <include file="$(find x_omni4wd_control)/launch/gazebo_velocity_control.launch">
    <arg name="world" value="$(arg world)" />
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="x" value="$(arg x)" />
    <arg name="y" value="$(arg y)" />
    <arg name="z" value="$(arg z)" />
    <arg name="urdf_file" value="$(arg urdf_file)" />
    <arg name="use_rviz" value="false" />  <!-- We'll launch RViz separately with SLAM config -->
    <arg name="use_rqt_robot_steering" value="$(arg use_rqt_robot_steering)" />
  </include>

  <!-- RF2O Laser Odometry -->
  <node name="rf2o_laser_odometry"
        pkg="x_omni4wd_slam"
        type="x_omni4wd_slam_node"
        output="screen">
    <param name="laser_scan_topic" value="$(arg scan_topic)"/>
    <param name="odom_topic" value="/odom"/>
    <param name="publish_tf" value="true"/>
    <param name="base_frame_id" value="$(arg base_frame)"/>
    <param name="odom_frame_id" value="$(arg odom_frame)"/>
    <param name="init_pose_from_topic" value=""/>
    <param name="freq" value="20.0"/>
  </node>

  <!-- Hector SLAM -->
  <node name="hector_mapping" pkg="hector_mapping" type="hector_mapping" output="screen">
    <param name="use_sim_time" value="$(arg use_sim_time)"/>
    <rosparam file="$(find x_omni4wd_slam)/config/hector_x_omni4wd.yaml" command="load"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>

  <!-- RViz with SLAM configuration -->
  <node if="$(arg use_rviz)"
        name="rviz"
        pkg="rviz"
        type="rviz"
        args="-d $(arg rviz_config)"
        respawn="false"
        output="screen" />

</launch>
