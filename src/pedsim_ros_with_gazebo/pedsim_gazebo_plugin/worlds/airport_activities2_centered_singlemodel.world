          <geometry><box><size>15 0.2 2.8</size></box></geometry>
        </collision>
        <visual name="wall_5_visual">
          <pose frame=''>17.5 -15 1.4 0 0 0</pose>
          <geometry><box><size>15 0.2 2.8</size></box></geometry>
        </visual>

        <collision name="wall_6_collision">
          <pose frame=''>-27.5 15 1.4 0 0 0</pose>
          <geometry><box><size>5 0.2 2.8</size></box></geometry>
